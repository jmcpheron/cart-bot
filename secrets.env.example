# Copy to secrets.env (gitignored) and fill in. Used by:
#   - firmware/load_secrets.py  → injects HOME_WIFI_* defines at build time,
#     so the robot and camera ESP32s can join the home LAN.
# Leave unset (or delete secrets.env) to build AP-only firmware.
HOME_WIFI_SSID=my-network
HOME_WIFI_PASS=my-password
